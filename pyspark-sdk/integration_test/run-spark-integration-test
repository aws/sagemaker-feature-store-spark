#!/usr/bin/env python3

import subprocess
import os
import sys
import time
import random
import boto3
from botocore.exceptions import ClientError

DIST_DIR = "../dist"
BATCH_INGESTION_TEST_FILE_NAME = "BatchIngestionTest.py"
LAKE_FORMATION_HIVE_TEST_FILE_NAME = "LakeFormationHiveIngestionTest.py"
LAKE_FORMATION_ICEBERG_TEST_FILE_NAME = "LakeFormationIcebergIngestionTest.py"
LAKE_FORMATION_COMMON_FILE_NAME = "_lf_test_common.py"
EMR_TEST_CLUSTER_NAME = "SparkTestEmrCluster"


s3_client = boto3.client("s3")
emr_client = boto3.client("emr")
account_id = boto3.client("sts").get_caller_identity()["Account"]

TEST_S3_BUCKET = f"spark-test-bucket-{account_id}"

tars = list(filter(lambda file_name: "sagemaker_feature_store_pyspark" in file_name, os.listdir(DIST_DIR)))

if len(tars) == 0:
    exit("tar file not detected, please build the library and try again.")
elif len(tars) > 1:
    exit("Mutiple tar detected under in dist, please remove redundant tars and try again.")

pyspark_tar_name = tars[0]
pyspark_tar_path = os.path.join(DIST_DIR, pyspark_tar_name)
# Preserve the full original filename so PEP 427 wheel naming
# (name-version-python-abi-platform.whl) is retained; stripping it breaks pip.
pyspark_artifact_s3_name = pyspark_tar_name
current_time_stamp = int(time.time())
test_temp_dir = f"spark-test-temp-{current_time_stamp}"

# First, submit all dependent integration test files to test S3 bucket
print(f"Uploading the spark library test files to {TEST_S3_BUCKET}.")
s3_client.upload_file(pyspark_tar_path, TEST_S3_BUCKET, f"{test_temp_dir}/{pyspark_artifact_s3_name}")
s3_client.upload_file(BATCH_INGESTION_TEST_FILE_NAME, TEST_S3_BUCKET, f"{test_temp_dir}/{BATCH_INGESTION_TEST_FILE_NAME}")
s3_client.upload_file(LAKE_FORMATION_COMMON_FILE_NAME, TEST_S3_BUCKET, f"{test_temp_dir}/{LAKE_FORMATION_COMMON_FILE_NAME}")
s3_client.upload_file(LAKE_FORMATION_HIVE_TEST_FILE_NAME, TEST_S3_BUCKET, f"{test_temp_dir}/{LAKE_FORMATION_HIVE_TEST_FILE_NAME}")
s3_client.upload_file(LAKE_FORMATION_ICEBERG_TEST_FILE_NAME, TEST_S3_BUCKET, f"{test_temp_dir}/{LAKE_FORMATION_ICEBERG_TEST_FILE_NAME}")
print("Upload finished.")

# Fetch the latest EMR cluster's Id that is still working
clusters = emr_client.list_clusters(
    ClusterStates=["STARTING", "BOOTSTRAPPING", "RUNNING", "WAITING"],
)["Clusters"]
clusters = list(filter(lambda cluster: cluster["Name"] == EMR_TEST_CLUSTER_NAME, clusters))
clusters.sort(key=lambda cluster: cluster["Status"]["Timeline"]["CreationDateTime"], reverse=True)
if not clusters:
    sys.exit(f"No active EMR cluster found with name: {EMR_TEST_CLUSTER_NAME}")
cluster_id = clusters[0]["Id"]
hadoop_test_temp_dir = f'/home/hadoop/{test_temp_dir}'
venv_python = f'{hadoop_test_temp_dir}/venv/bin/python3'
venv_pip = f'{hadoop_test_temp_dir}/venv/bin/pip'

# Add workflow steps to EMR
step_ids = emr_client.add_job_flow_steps(
    JobFlowId=cluster_id,
    Steps=[
        {
            'Name': 'Test Preparation',
            'ActionOnFailure': 'CONTINUE',
            'HadoopJarStep': {
                'Jar': 'command-runner.jar',
                'Args': [
                    "bash",
                    "-c",
                    # All deps go into a throwaway venv under the test temp dir so
                    # nothing persists on the cluster's root volume between runs.
                    f'set -e;'
                    f'mkdir {hadoop_test_temp_dir};'
                    f'aws s3 cp --recursive s3://{TEST_S3_BUCKET}/{test_temp_dir} {hadoop_test_temp_dir};'
                    f'cd {hadoop_test_temp_dir};'
                    f'python3 -m venv --system-site-packages venv;'
                    f'{venv_pip} install --no-cache-dir --upgrade pip;'
                    f'{venv_pip} install --no-cache-dir --prefer-binary '
                    f'  boto3 numpy "sagemaker-mlops>=1.8.0" "sagemaker-core>=2.8.0" "pyiceberg[glue,pyarrow,pandas]>=0.9.0";'
                    f'{venv_pip} install --no-cache-dir {pyspark_artifact_s3_name}'
                ]
            }
        },
        {
            'Name': 'Run Spark Integration Test',
            'ActionOnFailure': 'CONTINUE',
            'HadoopJarStep': {
                'Jar': 'command-runner.jar',
                'Args': [
                    "bash",
                    "-c",
                    f'export PYTHONPATH="/usr/lib/spark/python:/usr/lib/spark/python/lib/py4j-src.zip:$PYTHONPATH";'
                    f'{venv_python} {hadoop_test_temp_dir}/{BATCH_INGESTION_TEST_FILE_NAME}'
                ]
            }
        },
        {
            'Name': 'Run Lake Formation Hive Integration Test',
            'ActionOnFailure': 'CONTINUE',
            'HadoopJarStep': {
                'Jar': 'command-runner.jar',
                'Args': [
                    "bash",
                    "-c",
                    f'export PYTHONPATH="/usr/lib/spark/python:/usr/lib/spark/python/lib/py4j-src.zip:$PYTHONPATH";'
                    f'{venv_python} {hadoop_test_temp_dir}/{LAKE_FORMATION_HIVE_TEST_FILE_NAME}'
                ]
            }
        },
        {
            'Name': 'Run Lake Formation Iceberg Integration Test',
            'ActionOnFailure': 'CONTINUE',
            'HadoopJarStep': {
                'Jar': 'command-runner.jar',
                'Args': [
                    "bash",
                    "-c",
                    f'export PYTHONPATH="/usr/lib/spark/python:/usr/lib/spark/python/lib/py4j-src.zip:$PYTHONPATH";'
                    f'{venv_python} {hadoop_test_temp_dir}/{LAKE_FORMATION_ICEBERG_TEST_FILE_NAME}'
                ]
            }
        },
        {
            'Name': 'Spark Integration Test Cleanup',
            'ActionOnFailure': 'CONTINUE',
            'HadoopJarStep': {
                'Jar': 'command-runner.jar',
                'Args': [
                    "bash",
                    "-c",
                    # Deleting the temp dir nukes the venv and all test artifacts.
                    f'rm -rf {hadoop_test_temp_dir}'
                ]
            }
        }
    ]
)['StepIds']

pending_steps_id_list = step_ids

def list_steps_with_retry(emr_client, cluster_id, step_ids, max_retries=5):
    for attempt in range(max_retries):
        try:
            return emr_client.list_steps(
                ClusterId=cluster_id,
                StepIds=step_ids,
            )["Steps"]
        except ClientError as e:
            if e.response['Error']['Code'] == 'ThrottlingException' and attempt < max_retries - 1:
                wait = (2 ** attempt) + random.uniform(0, 1)
                print(f"Throttled on ListSteps, retrying in {wait:.1f}s...")
                time.sleep(wait)
            else:
                raise

while True:

    steps = list_steps_with_retry(emr_client, cluster_id, pending_steps_id_list)

    for step in steps:
        if step["Status"]["State"] in ['CANCELLED', 'FAILED', 'INTERRUPTED', 'CANCEL_PENDING']:
            exit(f"Integration test failed, cluster id:{cluster_id}, step id: {step['Id']}, step name: {step['Name']}, "
                 f"please log in the console to root cause the test failure.")
        elif step["Status"]["State"] == 'COMPLETED':
            pending_steps_id_list.remove(step['Id'])
        else:
            print(f"Step [{step['Name']}] is in {step['Status']['State']} state, cluster id:{cluster_id}, "
                  f"step id: {step['Id']}.")
    if len(pending_steps_id_list) == 0:
        break

    # Sleep longer to avoid throttling with parallel matrix jobs
    print("=================================================================")
    time.sleep(30 + random.uniform(0, 10))

print("Spark library integration test succeeded!")
